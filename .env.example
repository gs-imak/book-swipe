# BookSwipe environment variables. Copy to `.env.local` and fill in.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser — never put secrets there.

# ── Book data (server-only) ──────────────────────────────────────────────────
# Google Books API key. Proxied through /api/books; do NOT prefix NEXT_PUBLIC.
GOOGLE_BOOKS_API_KEY=

# ── Cloud sync + accounts (optional; omit to run fully local/anonymous) ───────
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — ONLY used by scripts/setup-db.mjs. Never shipped to client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Error monitoring (optional) ───────────────────────────────────────────────
# Sentry DSN. When set, client errors are reported. Inert when empty.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production

# ── AI recommendations (optional) ─────────────────────────────────────────────
# Enables the LLM-direct recommender (ADR-0003): personalized book picks +
# "why this book" reasons. Routed through the Vercel AI Gateway. When unset, the
# app falls back to the local TF-IDF scoring engine (no recommendations call).
# Get a key from the Vercel dashboard → AI Gateway. (On Vercel you can instead
# use OIDC via `vercel env pull` — no key to rotate.)
AI_GATEWAY_API_KEY=
# Optional model override (Vercel AI Gateway slug). Default: anthropic/claude-haiku-4.5
RECOMMENDER_MODEL=

# ── Rate limiting (optional, recommended for production) ──────────────────────
# Upstash Redis REST credentials. When set, API proxy rate limits are shared
# across all serverless instances/regions (real protection). When empty, a
# best-effort per-instance in-memory limiter is used. Create a free DB at
# upstash.com → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Analytics (optional, cookieless) ──────────────────────────────────────────
# Plausible domain (e.g. bookswipe.app). When set, the tracker loads. No cookies,
# so no consent banner needed. Leave empty to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Override only if self-hosting Plausible / using a proxy.
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
